# Copy this file to config.env and fill in your values.
# config.env is gitignored and will never be committed.
#
# Run ./setup.sh to apply these settings, then build.
# WiFi credentials are configured via the web portal on first boot.

# ── MQTT broker ───────────────────────────────────────────────────────────────
# No auth:   mqtt://192.168.1.x:1883
# With auth: mqtt://username:password@192.168.1.x:1883
# TLS:       mqtts://192.168.1.x:8883
MQTT_BROKER=

# ── Home Assistant ────────────────────────────────────────────────────────────
# Base URL (no trailing slash)
HA_URL=http://192.168.1.x:8123

# Long-lived access token:
# HA → Profile → Security → Long-lived access tokens → Create token
HA_TOKEN=
